msgstr ""
"%(addonName)s er avgrensa fordi tillegget vart sletta av utviklaren/"
"utviklarane"

#: src/amo/pages/Block/index.js:165
msgid "This add-on is restricted because it was deleted by the author(s)"
msgstr ""
"Dette tillegget er avgrensa fordi det vart sletta av utviklaren/utviklarane"

