msgstr "Témaalkotó"

#: src/amo/pages/UserProfile/index.js:335 src/amo/pages/UserProfileEdit/index.js:551
msgid "User Profile for %(user)s"
msgstr "%(user)s felhasználói profilja"

#: src/amo/pages/UserProfile/index.js:338
